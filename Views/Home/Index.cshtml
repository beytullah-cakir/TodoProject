@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-8 text-center">
        <div class="glass-card p-5">
            <div class="mb-4">
                <i class="bi bi-rocket-takeoff-fill text-primary display-1"></i>
            </div>
            <h1 class="display-3 fw-bold mb-3">TaskMaster'a Hoş Geldiniz</h1>
            <p class="lead text-muted mb-5">
                Modern, hızlı ve şık bir yapılacaklar listesi deneyimi. 
                Görevinizi ekleyin, odaklanın ve başarın.
            </p>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a asp-controller="Todo" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3">
                    <i class="bi bi-list-check me-2"></i> Görevlerime Git
                </a>
            </div>
        </div>
    </div>
</div>
